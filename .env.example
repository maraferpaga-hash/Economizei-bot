# =============================================================================
# Economizei Bot — variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
#   cp .env.example .env
# NUNCA faça commit do .env — ele já está no .gitignore.
# =============================================================================

# --- Google AI Studio (Gemini) -----------------------------------------------
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# --- Supabase ----------------------------------------------------------------
# Obter em: Painel do projeto → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=SUA_CHAVE_ANON_SUPABASE_AQUI
# service_role key — usada no servidor (bypassa RLS). NUNCA expor ao cliente.
# Necessária para ativar o RLS (ver supabase/rls_migration.sql)
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI

# --- Z-API (gateway WhatsApp) ------------------------------------------------
# Obter em: app.z-api.io → sua instância → Credenciais
ZAPI_INSTANCE_ID=SEU_INSTANCE_ID_AQUI
ZAPI_TOKEN=SEU_TOKEN_AQUI
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN_AQUI

# --- Servidor ----------------------------------------------------------------
# Porta em que o Express vai escutar (Railway injeta automaticamente)
PORT=3000
# Scheduler — secret para autenticar disparos externos do cron mensal
# Gere com: openssl rand -hex 32
CRON_SECRET=
# Admin — secret para autenticar o endpoint GET /admin/metrics
# Gere com: openssl rand -hex 32
ADMIN_SECRET=
# Seu número pessoal para receber alertas do bot (Z-API desconectado,
# digest semanal, etc.). Formato: DDI + DDD + número sem '+' (ex: 5517999999999)
ADMIN_PHONE=

# --- Relatório semanal (digest dos "3 números") ------------------------------
# Chave read-only da conta UptimeRobot, para o digest puxar o uptime do /health.
# Obter em: uptimerobot.com → My Settings → API → "Read-Only API Key".
# Se ficar vazio, o digest ainda manda cadastros e visitas, só sem o uptime.
UPTIMEROBOT_API_KEY=
# Link direto do painel de Analytics do Vercel (aparece no digest como lembrete
# pra leitura manual das visitas — o plano free não expõe API estável).
# Ex: https://vercel.com/SEU_TIME/economizei/analytics
LANDING_ANALYTICS_URL=