# =============================================================================
# Economizei Bot — variáveis de ambiente
# Copie este arquivo para .env e preencha com suas credenciais reais.
#   cp .env.example .env
# NUNCA faça commit do .env — ele já está no .gitignore.
# =============================================================================

# --- Google AI Studio (Gemini) -----------------------------------------------
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=SUA_CHAVE_GEMINI_AQUI

# --- Supabase ----------------------------------------------------------------
# Obter em: Painel do projeto → Settings → API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=SUA_CHAVE_ANON_SUPABASE_AQUI
# service_role key — usada no servidor (bypassa RLS). NUNCA expor ao cliente.
# Necessária para ativar o RLS (ver supabase/rls_migration.sql)
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY_AQUI

# --- Z-API (gateway WhatsApp) ------------------------------------------------
# Obter em: app.z-api.io → sua instância → Credenciais
ZAPI_INSTANCE_ID=SEU_INSTANCE_ID_AQUI
ZAPI_TOKEN=SEU_TOKEN_AQUI
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN_AQUI

# --- Servidor ----------------------------------------------------------------
# Porta em que o Express vai escutar (Railway injeta automaticamente)
PORT=3000
# Scheduler — secret para autenticar disparos externos do cron mensal
# Gere com: openssl rand -hex 32
CRON_SECRET=
# Admin — secret para autenticar o endpoint GET /admin/metrics
# Gere com: openssl rand -hex 32
ADMIN_SECRET=
# Seu número pessoal para receber alertas do bot (Z-API desconectado,
# digest semanal, etc.). Formato: DDI + DDD + número sem '+' (ex: 5517999999999)
ADMIN_PHONE=
# Número do WhatsApp DO BOT — usado para montar o link wa.me do /convidar.
# Formato: DDI + DDD + número sem '+' (ex: 5517999999999). Sem isso, o /convidar
# devolve só o código em vez do link clicável.
BOT_PHONE=

# --- Relatório semanal (digest dos "3 números") ------------------------------
# Chave read-only da conta UptimeRobot, para o digest puxar o uptime do /health.
# Obter em: uptimerobot.com → My Settings → API → "Read-Only API Key".
# Se ficar vazio, o digest ainda manda cadastros e visitas, só sem o uptime.
UPTIMEROBOT_API_KEY=
# Link direto do painel de Analytics do Vercel (aparece no digest como lembrete
# pra leitura manual das visitas — o plano free não expõe API estável).
# Ex: https://vercel.com/SEU_TIME/economizei/analytics
LANDING_ANALYTICS_URL=

# --- Alerta de gasto (comparação com a média histórica) ----------------------
# Limiar acima da média para disparar o alerta "acima do padrão" (fração, não %).
# Ex: 0.20 = avisa quando a compra passa 20% acima da média. Default: 0.20
ALERTA_LIM_ACIMA=0.20
# Limiar abaixo da média para a mensagem de economia (fração). Default: 0.15
ALERTA_LIM_ABAIXO=0.15
# Quando o bot fala depois de um cupom de mercado:
#   relevante (default) → só quando foge do padrão (acima OU abaixo)
#   sempre              → todo cupom recebe retorno (acima/abaixo/dentro)
#   so_acima            → só quando estoura para cima (comportamento legado)
ALERTA_MODO=relevante

# --- Pagamento PIX (manual) --------------------------------------------------
# Chave PIX usada nas instruções do comando /pix. Pode ser e-mail, telefone,
# CPF ou chave aleatória. Sem isso, o bot mostra "[chave PIX a configurar]".
PIX_KEY=

# --- Mercado Pago (assinatura recorrente no cartão) --------------------------
# Conta: a mesma do seu banco Mercado Pago. Crie uma "aplicação" em
#   https://www.mercadopago.com.br/developers/panel/app
# e copie o Access Token de PRODUÇÃO (começa com APP_USR-...).
# Em testes, use o Access Token de TESTE (começa com TEST-...).
MP_ACCESS_TOKEN=
# Secret de validação do webhook (assinatura x-signature). Gerado no painel da
# aplicação → Webhooks. Sem ele, o bot ainda funciona (reconsulta o MP), mas
# fica sem a validação HMAC de defesa em profundidade. Altamente recomendado.
MP_WEBHOOK_SECRET=
# URL pública que o MP vai chamar a cada evento de assinatura. Aponte para o
# endpoint do bot no Railway. Ex: https://seu-bot.up.railway.app/webhook/mercadopago
MP_WEBHOOK_URL=
# Para onde o usuário é redirecionado após pagar (página de obrigado/landing).
# Ex: https://economizei.app/obrigado  (default: https://economizei.app)
MP_BACK_URL=