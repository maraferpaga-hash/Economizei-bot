// ---------------------------------------------------------------
// Mercado Pago — Assinaturas recorrentes no cartão (preapproval)
//
// Modelo: "assinatura sem plano associado". Para cada usuário criamos
// um preapproval com external_reference = phone_number e o MP devolve
// um init_point (link de checkout hospedado). O cartão é cadastrado lá,
// nunca no nosso servidor (PCI fica com o MP). A partir do 1º pagamento,
// o MP cobra automaticamente todo mês e nos avisa por webhook.
//
// Decisão técnica: ver CODE_GUIDE.md (2026-06-07).
// Padrão de retorno: { ok: true, ... } | { ok: false, error }.
// HTTP via fetch nativo (Node ≥ 18) — sem dependência nova.
// ---------------------------------------------------------------

const crypto = require('crypto');
const { log } = require('./logger');

const MP_API = 'https://api.mercadopago.com';

// Catálogo de planos pagos. Espelha CLAUDE.md seção 3 e formatter.js.
const PLANOS = {
  individual:   { valor: 9.90,  label: 'Individual',  descricao: 'Economizei Individual' },
  familia:      { valor: 15.00, label: 'Família',     descricao: 'Economizei Família' },
  familia_plus: { valor: 22.00, label: 'Família+',    descricao: 'Economizei Família+' },
};

// Normaliza entradas do usuário ("familia+", "familia plus", "família") para a chave canônica.
function normalizarPlano(entrada) {
  if (!entrada) return null;
  const s = String(entrada)
    .toLowerCase()
    .normalize('NFD').replace(/[̀-ͯ]/g, '') // remove acentos
    .trim();
  if (s === 'individual' || s === 'pro') return 'individual';
  if (s === 'familia') return 'familia';
  if (s === 'familia+' || s === 'familiamais' || s === 'familia plus' || s === 'familiaplus' || s === 'familia_plus') {
    return 'familia_plus';
  }
  return null;
}

function _accessToken() {
  const token = process.env.MP_ACCESS_TOKEN;
  if (!token) throw new Error('MP_ACCESS_TOKEN não configurado');
  return token;
}

// ---------------------------------------------------------------
// Cria a assinatura (preapproval) e retorna o link de checkout.
// ---------------------------------------------------------------
async function criarAssinatura({ phone, email, plano }) {
  try {
    const chavePlano = normalizarPlano(plano);
    const cfg = chavePlano && PLANOS[chavePlano];
    if (!cfg) return { ok: false, error: 'plano_invalido' };

    const body = {
      reason: cfg.descricao,
      external_reference: phone,            // chave de conciliação webhook → usuário
      payer_email: email,
      back_url: process.env.MP_BACK_URL || 'https://economizei.app',
      status: 'pending',                    // 'pending' → gera init_point para o usuário pagar
      auto_recurring: {
        frequency: 1,
        frequency_type: 'months',
        transaction_amount: cfg.valor,
        currency_id: 'BRL',
      },
    };

    // Webhook por assinatura: para Subscriptions o MP recomenda configurar a
    // notification_url na criação (o painel "Suas integrações" não cobre
    // assinaturas). Ver webhooks.md.
    if (process.env.MP_WEBHOOK_URL) {
      body.notification_url = process.env.MP_WEBHOOK_URL;
    }

    const resp = await fetch(`${MP_API}/preapproval`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${_accessToken()}`,
        'X-Idempotency-Key': `${phone}-${chavePlano}-${Date.now()}`,
      },
      body: JSON.stringify(body),
    });

    const data = await resp.json().catch(() => ({}));

    if (!resp.ok) {
      log('mp_criar_assinatura_erro', { status: resp.status, msg: data?.message, plano: chavePlano });
      return { ok: false, error: data?.message || `HTTP ${resp.status}` };
    }

    const initPoint = data.init_point || data.sandbox_init_point;
    if (!data.id || !initPoint) {
      log('mp_criar_assinatura_sem_link', { id: data?.id, tem_init: !!initPoint });
      return { ok: false, error: 'resposta_sem_init_point' };
    }

    log('mp_assinatura_criada', { plano: chavePlano, preapproval_id: data.id, status: data.status });
    return { ok: true, preapprovalId: data.id, initPoint, status: data.status, plano: chavePlano };
  } catch (err) {
    log('mp_criar_assinatura_excecao', { erro: err.message });
    return { ok: false, error: err.message };
  }
}

// ---------------------------------------------------------------
// Consulta o estado atual de uma assinatura (fonte da verdade).
// Sempre chamada antes de ligar/desligar is_pro — torna o fluxo
// seguro mesmo se o webhook for forjado (a verdade vem do MP).
// ---------------------------------------------------------------
async function consultarAssinatura(preapprovalId) {
  try {
    const resp = await fetch(`${MP_API}/preapproval/${preapprovalId}`, {
      headers: { 'Authorization': `Bearer ${_accessToken()}` },
    });
    const data = await resp.json().catch(() => ({}));
    if (!resp.ok) {
      log('mp_consultar_assinatura_erro', { status: resp.status, preapproval_id: preapprovalId });
      return { ok: false, error: data?.message || `HTTP ${resp.status}` };
    }
    return {
      ok: true,
      id: data.id,
      status: data.status,                      // authorized | paused | cancelled | pending
      externalReference: data.external_reference,
      payerEmail: data.payer_email,
      proximaCobranca: data.next_payment_date || null,
      raw: data,
    };
  } catch (err) {
    log('mp_consultar_assinatura_excecao', { erro: err.message });
    return { ok: false, error: err.message };
  }
}

// ---------------------------------------------------------------
// Consulta um pagamento recorrente (authorized_payment) — usado no
// tópico subscription_authorized_payment para saber se a renovação
// foi aprovada ou recusada.
// ---------------------------------------------------------------
async function consultarPagamentoRecorrente(authorizedPaymentId) {
  try {
    const resp = await fetch(`${MP_API}/authorized_payments/${authorizedPaymentId}`, {
      headers: { 'Authorization': `Bearer ${_accessToken()}` },
    });
    const data = await resp.json().catch(() => ({}));
    if (!resp.ok) {
      log('mp_consultar_pagamento_erro', { status: resp.status, id: authorizedPaymentId });
      return { ok: false, error: data?.message || `HTTP ${resp.status}` };
    }
    return {
      ok: true,
      preapprovalId: data.preapproval_id,
      status: data.status,                      // scheduled | processed | recycling | ...
      statusPagamento: data.payment?.status,    // approved | rejected
      raw: data,
    };
  } catch (err) {
    log('mp_consultar_pagamento_excecao', { erro: err.message });
    return { ok: false, error: err.message };
  }
}

// ---------------------------------------------------------------
// Cancela a assinatura no MP (usado no comando /cancelar-assinatura).
// ---------------------------------------------------------------
async function cancelarAssinatura(preapprovalId) {
  try {
    const resp = await fetch(`${MP_API}/preapproval/${preapprovalId}`, {
      method: 'PUT',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${_accessToken()}`,
      },
      body: JSON.stringify({ status: 'cancelled' }),
    });
    const data = await resp.json().catch(() => ({}));
    if (!resp.ok) {
      log('mp_cancelar_assinatura_erro', { status: resp.status, preapproval_id: preapprovalId });
      return { ok: false, error: data?.message || `HTTP ${resp.status}` };
    }
    log('mp_assinatura_cancelada', { preapproval_id: preapprovalId });
    return { ok: true, status: data.status };
  } catch (err) {
    log('mp_cancelar_assinatura_excecao', { erro: err.message });
    return { ok: false, error: err.message };
  }
}

// ---------------------------------------------------------------
// Valida a assinatura HMAC do webhook (header x-signature).
// Algoritmo oficial (webhooks.md): manifest = id:{data.id};request-id:{x-request-id};ts:{ts};
// HMAC-SHA256(secret, manifest) === v1.
//
// Se MP_WEBHOOK_SECRET não estiver setado, retorna { validado:false, motivo:'sem_secret' }
// — o chamador decide o que fazer. (No nosso fluxo, mesmo sem validar a
// assinatura, sempre reconsultamos o recurso no MP antes de ligar is_pro,
// então um webhook forjado não consegue ativar Pro.)
// ---------------------------------------------------------------
function validarAssinaturaWebhook({ xSignature, xRequestId, dataId }) {
  const secret = process.env.MP_WEBHOOK_SECRET;
  if (!secret) return { validado: false, motivo: 'sem_secret' };
  if (!xSignature) return { validado: false, motivo: 'sem_header' };

  let ts = null;
  let v1 = null;
  for (const parte of String(xSignature).split(',')) {
    const [k, val] = parte.split('=').map((s) => (s || '').trim());
    if (k === 'ts') ts = val;
    else if (k === 'v1') v1 = val;
  }
  if (!ts || !v1) return { validado: false, motivo: 'header_malformado' };

  // data.id alfanumérico deve ir em minúsculas (regra do MP).
  const idNormalizado = /^[a-zA-Z0-9]+$/.test(String(dataId)) ? String(dataId).toLowerCase() : String(dataId);

  let manifest = `id:${idNormalizado};`;
  if (xRequestId) manifest += `request-id:${xRequestId};`;
  manifest += `ts:${ts};`;

  const calculado = crypto.createHmac('sha256', secret).update(manifest).digest('hex');

  // timingSafeEqual exige buffers do mesmo tamanho
  const a = Buffer.from(calculado, 'utf8');
  const b = Buffer.from(v1, 'utf8');
  const validado = a.length === b.length && crypto.timingSafeEqual(a, b);

  if (!validado) log('mp_webhook_assinatura_invalida', { data_id: String(dataId) });
  return { validado, motivo: validado ? 'ok' : 'hmac_mismatch' };
}

module.exports = {
  PLANOS,
  normalizarPlano,
  criarAssinatura,
  consultarAssinatura,
  consultarPagamentoRecorrente,
  cancelarAssinatura,
  validarAssinaturaWebhook,
};
