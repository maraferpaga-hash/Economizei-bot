{
  "name": "economizei-bot",
  "version": "1.0.0",
  "description": "Bot de WhatsApp para leitura de cupons fiscais via Z-API e Gemini Vision",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "node --test \"test/**/*.test.js\"",
    "check": "node scripts/check-firewall.mjs --working && node --test \"test/**/*.test.js\" && node scripts/check-pages.mjs",
    "check:push": "node scripts/check-firewall.mjs && node --test \"test/**/*.test.js\" && node scripts/check-pages.mjs",
    "check:firewall": "node scripts/check-firewall.mjs --working",
    "validate:pages": "node scripts/check-pages.mjs",
    "ship": "node scripts/ship.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "node-cron": "^4.2.1",
    "sharp": "^0.34.5",
    "ws": "^8.18.0"
  }
}
